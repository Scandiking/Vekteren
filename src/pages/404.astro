---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Siden finnes ikke" description="Siden du ser etter finnes ikke, eller har flyttet.">
  <div class="max-w-xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-orange-500 font-extrabold text-6xl mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3">
      Fant ikke siden
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      Lenken kan være feil, eller siden har flyttet. Prøv en av disse:
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="btn-primary">Til forsiden</a>
      <a href="/kalkulatorer" class="px-4 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        Kalkulatorer
      </a>
      <a href="/artikler" class="px-4 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        Artikler
      </a>
    </div>
  </div>
</BaseLayout>
