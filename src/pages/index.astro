---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { totalLoss } from '../config';

const alleArtikler = await getCollection('artikler');
const sisteArtikler = alleArtikler
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const prinsipper = [
  {
    icon: '⚖️',
    title: 'Kalorier er nøkkelen',
    body: 'Kroppen er en motor. Gir du den mer energi enn den bruker, lagrer den resten som fett. Et kaloriunderskudd er det eneste som gir varig vektnedgang – uten unntak. Kroppen trenger kalorier, men hva de kaloriene består av er nøkkelen til å endre livsstil.',
  },
  {
    icon: '🐢',
    title: 'Langsomhet vinner',
    body: '0,2 – 0,5 kg per uke er ikke sakte. Det er bærekraftig. Raske kurer gir raske resultater OG rask tilbakegang. Tålmodighet er det viktigste verktøyet ditt. Du skal tross alt motarbeide kroppens overlevelsesinstinkt, som vil gjøre alt for å beholde fettet.',
  },
  {
    icon: '🥑',
    title: 'Fett er ikke fienden',
    body: 'Fett er et essensielt næringsstoff kroppen din trenger. Det metter godt, og det gjør maten god. Å kutte fett for å spare kalorier er en felle mange går i. Det er mye smartere å kutte raffinerte karbohydrater og sukker, og heller spise mer av det som faktisk metter og nærer kroppen – som fett, fiber og protein.',
  },
  {
    icon: '🏃',
    title: 'Beveg deg – men riktig grunn',
    body: 'Trening er fantastisk for helsen, humøret og muskelmassen. Men den driver ikke vektnedgang alene. Kjøkkenet er der den største jobben gjøres. Men ved å trene de store muskelgruppene, og prioritere styrketrening, kan du hjelpe kroppen å beholde muskelmasse mens den mister fett – og det gjør at du ser bedre ut, føler deg sterkere, og unngår det klassiske "skinny fat"-problemet.',
  },
];
---

<BaseLayout title="Hjem" description="Vektnedgang som faktisk fungerer – ingen mirakelkurer, bare kalorier, tålmodighet og riktig mat.">

  <!-- Hero -->
  <section class="min-h-[85vh] flex items-center bg-white dark:bg-gray-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-3xl animate-slide-up">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100 dark:bg-orange-500/15 text-orange-600 dark:text-orange-400 text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
          Ingen mirakelkurer, slankepiller eller salg av abbonement her
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gray-900 dark:text-white leading-none mb-6">
          Vektnedgang<br />
          <span class="text-orange-500">som faktisk</span><br />
          fungerer.
        </h1>

        <p class="text-xl text-gray-500 dark:text-gray-400 mb-8 max-w-xl leading-relaxed">
          Slanking? Gjør det enkelt. Ingen sulting, ingen kurer, ingen mirakler. Bare et solid kaloriunderskudd,
          tålmodighet, og kunnskap om hva du faktisk spiser. Jeg har vært der, og jeg har lært det på den harde måten – nå deler jeg alt jeg vet, og alt jeg har erfart.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/fremgang" class="btn-primary">
            Se min reise
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/kalorier" class="btn-secondary">
            Les om kalorier
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key principles -->
  <section class="bg-gray-50 dark:bg-gray-900">
    <div class="section-wrap">
      <h2 class="section-title">Fire prinsipper</h2>
      <p class="section-sub">Alt du trenger å vite kan egentlig oppsummeres i fire punkter. Det betyr ikke at det er lett, men det er enkelt å sette seg inn i og forholde seg til.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {prinsipper.map(p => (
          <div class="card hover:border-orange-500/50 transition-colors duration-200">
            <div class="text-4xl mb-4">{p.icon}</div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{p.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Kris -->
  <section class="bg-white dark:bg-gray-950">
    <div class="section-wrap">
      <div class="max-w-3xl">
        <div class="inline-block text-xs uppercase tracking-widest font-semibold text-orange-500 mb-3">Om Kris</div>
        <h2 class="section-title">Jeg er ikke ekspert. Hvorfor høre på meg?</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
          Jeg heter Kris, og dette nettstedet er ikke skrevet av en ernæringsfysiolog eller personlig trener.
          Det er skrevet av en vanlig person som faktisk gikk ned {totalLoss > 0 ? `${totalLoss} kg` : 'mye'} – sakte, bærekraftig, og uten å ofre matgleden. 
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
          Det jeg skriver her er basert på det som faktisk fungerte for meg, supplert med det vitenskapen sier.
          Ingenting er hokuspokus. Ingen supplementreklame. Ingen kurer å kjøpe. På videregående etter å ha begynt å drikke Coca-Cola på ettermiddagen når jeg skulle locke inn på matematikk startet min reise mot å bli overvektig. Det snek seg gradvis på, og jeg prøvde runder med økt trening og dietter. Mange runder. Vet du hva det kalles? Jojo-slanking. Dette er ikke en fase med en diett du går igjennom og når du har nådd målet så går du tilbake til samme kosthold. Det er en livsstil-endring. Og da kan man ikke gjøre store endringer på en gang, det er ikke bærekraftig. Det handler om å gjøre små, smarte valg hver dag, og å være tålmodig nok til å la kroppen tilpasse seg og endre seg over tid.
        </p>
        <a href="/fremgang" class="btn-primary">
          Se reisen min
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  {sisteArtikler.length > 0 && (
    <section class="bg-gray-50 dark:bg-gray-900">
      <div class="section-wrap">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="section-title mb-1">Siste artikler</h2>
            <p class="text-gray-500 dark:text-gray-400">Tanker, erfaringer og fordypninger.</p>
          </div>
          <a href="/artikler" class="text-sm font-medium text-orange-500 hover:text-orange-600 transition-colors">
            Se alle →
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {sisteArtikler.map(artikkel => (
            <a href={`/artikler/${artikkel.slug}`} class="card hover:border-orange-500/50 transition-all duration-200 hover:-translate-y-1 group">
              <div class="flex flex-wrap gap-2 mb-3">
                {artikkel.data.tags.map((tag: string) => (
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 dark:bg-orange-500/15 text-orange-600 dark:text-orange-400">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-orange-500 transition-colors mb-2">
                {artikkel.data.title}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-3">{artikkel.data.description}</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-4">
                {artikkel.data.publishDate.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Tools CTA -->
  <section class="bg-orange-500">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Vet du hva kroppen din trenger?</h2>
      <p class="text-orange-100 text-lg mb-8 max-w-xl mx-auto">
        Bruk kalkulatorene våre til å finne ditt daglige energibehov, BMI og en fornuftig makrofordeling.
      </p>
      <a href="/kalkulatorer" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-orange-600 font-bold rounded-lg hover:bg-orange-50 transition-colors">
        Åpne kalkulatorer
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
