      </nav>

    </div>

    <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 text-xs text-gray-400 dark:text-gray-500 flex flex-wrap gap-x-4 gap-y-1 items-center">
      <span>© {year} Kris · Ikke medisinsk rådgivning. Konsulter lege ved behov.</span>
      <a href="/personvern" class="hover:text-orange-500 transition-colors">Personvern</a>
    </div>
  </div>
</footer>
