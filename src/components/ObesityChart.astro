---
// Obesity trend chart — approximate Western prevalence data.
// Sources: WHO, OECD, NCD Risk Factor Collaboration (illustrative/approximate).
---

<div class="relative w-full">
  <canvas id="obesityChart"></canvas>
  <p class="text-xs text-gray-400 dark:text-gray-500 mt-3 text-center">
    Omtrentlig fedmeforekomst i vestlige land (%). Kilde: WHO / OECD / NCD-RisC (illustrativt).
  </p>
</div>

<script>
  import Chart from 'chart.js/auto';

  const labels = [
    '1960','1965','1970','1975','1977',
    '1980','1985','1990','1995',
    '2000','2005','2010','2015','2020','2025',
  ];

  const data = [4, 5, 6, 7, 8, 10, 13, 16, 19, 22, 24, 26, 28, 30, 32];

  // Index of the inflection year
  const pivotLabel = '1977';
  const pivotIndex = labels.indexOf(pivotLabel);

  const isDark = document.documentElement.classList.contains('dark');
  const gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
  const tickColor = isDark ? '#9ca3af' : '#6b7280';

  // Vertical line + annotation plugin (no external dependency)
  const verticalLinePlugin = {
    id: 'pivotLine',
    afterDraw(chart: Chart) {
      if (pivotIndex < 0) return;
      const meta = chart.getDatasetMeta(0);
      const point = meta.data[pivotIndex];
      if (!point) return;
      const { ctx, chartArea } = chart;
      const x = point.x;

      ctx.save();
      ctx.beginPath();
      ctx.setLineDash([5, 4]);
      ctx.strokeStyle = 'rgba(249,115,22,0.8)';
      ctx.lineWidth = 1.5;
      ctx.moveTo(x, chartArea.top);
      ctx.lineTo(x, chartArea.bottom);
      ctx.stroke();

      ctx.fillStyle = '#f97316';
      ctx.font = '11px Inter, system-ui, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText('Lavfett-anbefalingene + sukkerindustriens kampanje', x + 6, chartArea.top + 14);
      ctx.restore();
    },
  };

  const canvas = document.getElementById('obesityChart') as HTMLCanvasElement;

  new Chart(canvas, {
    type: 'line',
    plugins: [verticalLinePlugin],
    data: {
      labels,
      datasets: [
        {
          label: 'Fedmeforekomst (%)',
          data,
          borderColor: '#f97316',
          backgroundColor: 'rgba(249,115,22,0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3,
          pointHoverRadius: 6,
          borderWidth: 2.5,
        },
      ],
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `Fedme: ~${ctx.parsed.y}%`,
          },
        },
      },
      scales: {
        x: {
          ticks: { color: tickColor, font: { family: 'Inter, system-ui, sans-serif', size: 11 } },
          grid: { color: gridColor },
        },
        y: {
          min: 0,
          max: 35,
          ticks: {
            color: tickColor,
            callback: v => `${v}%`,
            font: { family: 'Inter, system-ui, sans-serif', size: 11 },
          },
          grid: { color: gridColor },
        },
      },
    },
  });
</script>
